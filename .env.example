# Botfactory brand settings
BOTFACTORY_BRAND_NAME=Botfactory AI
EMAIL_TRANSPORT=auto
EMAIL_SENDER_EMAIL=your_email@gmail.com
EMAIL_FROM_NAME=Botfactory AI
EMAIL_REPLY_TO=your_email@gmail.com
EMAIL_REPLY_PHRASE=Shunchaki 'Ha' deb javob yozing
EMAIL_UNSUBSCRIBE_TEXT=Agar ushbu mavzu sizga qiziq bo'lmasa, 'Stop' deb javob bering.
CUSTOM_SOLUTIONS_TEXT=Bundan tashqari, agar sizga biznesingiz uchun maxsus AI yechim kerak bo'lsa (masalan: data analytics, ichki CRM integratsiyasi, hujjatlar bilan ishlovchi AI yoki xodimlar uchun AI-yordamchi), biz uni aynan sizning talablaringiz asosida noldan ishlab chiqib bera olamiz.
DISCOVERY_CALL_URL=
EMAIL_SIGNATURE_NAME=Botfactory AI
EMAIL_SIGNATURE_ROLE=AI Automation Agency
EMAIL_SIGNATURE_COMPANY=Botfactory AI
EMAIL_SIGNATURE_PHONE=+998996448444
EMAIL_SIGNATURE_WEBSITE=https://botfactory.ai

# Gmail SMTP
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=replace_with_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_RETRY_LIMIT=3
EMAIL_REQUEST_TIMEOUT_SECONDS=30

# Gmail API transport for Render free
GMAIL_API_CLIENT_ID=YOUR_CLIENT_ID
GMAIL_API_CLIENT_SECRET=YOUR_CLIENT_SECRET
GMAIL_API_REFRESH_TOKEN=YOUR_REFRESH_TOKEN
GMAIL_API_TOKEN_URL=https://oauth2.googleapis.com/token
GMAIL_API_SEND_URL=https://gmail.googleapis.com/gmail/v1/users/me/messages/send


# Scraper settings
SCRAPE_SEED_URL=https://www.goldenpages.uz/uz/rubrics/?Id=4676
SCRAPER_MAX_COMPANIES=
SCRAPER_MAX_PAGES_PER_SEED=
SCRAPER_OUTPUT_DIR=output
LEADS_FILE=botfactory_leads.xlsx
TEMPLATE_FILE=template.html
OUTREACH_LANGUAGE=uz
GEMINI_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET=Leads
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
GOOGLE_SERVICE_ACCOUNT_FILE=
FILTER_PRIORITY_CATEGORIES=true
VALIDATE_EMAIL_MX=true
LOGS_DIR=logs
BLACKLIST_FILE=logs/blacklist.json

# Email sending behavior
EMAIL_DELAY_MIN_SECONDS=10
EMAIL_DELAY_MAX_SECONDS=20
EMAIL_MAX_PER_RUN=50
WARM_UP_MODE=true
WARM_UP_START_DAILY_LIMIT=5
WARM_UP_DAILY_INCREMENT=5
WARM_UP_MAX_DAILY_LIMIT=50
WARM_UP_STATE_FILE=logs/warmup_state.json

# Reply sync / unsubscribe
REPLY_SYNC_ENABLED=true
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_FOLDER=INBOX
UNSUBSCRIBE_KEYWORDS=stop,unsubscribe,remove,bekor

# Render web service
RENDER_TRIGGER_TOKEN=
RENDER_ENABLE_SCHEDULER=false
RENDER_SCHEDULE_CRON=0 6 * * *
RENDER_TIMEZONE=Asia/Tashkent

# Optional Telegram bot settings
TELEGRAM_BOT_TOKEN=replace_with_real_token
TELEGRAM_OUTPUT_DIR=telegram_output
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_SCRAPER_MIN_DELAY=1.2
TELEGRAM_SCRAPER_MAX_DELAY=3.2
TELEGRAM_SCRAPER_RETRIES=5
TELEGRAM_SCRAPER_TIMEOUT=25
TELEGRAM_SMS_MOBILE_PREFIXES=33,50,90,91,93,94,95,97,98,99
TELEGRAM_GOOGLE_CONTACTS_LABELS=Botfactory SMS Leads:::GoldenPages
